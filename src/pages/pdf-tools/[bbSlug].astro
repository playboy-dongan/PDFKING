---
import BrowserboundPlaceholderPage from '../../components/pages/BrowserboundPlaceholderPage.astro';
import ToolPage from '../../components/pages/ToolPage.astro';
import { browserboundPdfAliases } from '../../data/browserbound-routes';
import { defaultLocale } from '../../data/tools';

export const prerender = false;

const bbSlug = Astro.params.bbSlug ?? '';
const toolSlug = browserboundPdfAliases[bbSlug];
---

{toolSlug ? <ToolPage locale={defaultLocale} slug={toolSlug} /> : <BrowserboundPlaceholderPage section="pdf-tools" slug={bbSlug} />}
