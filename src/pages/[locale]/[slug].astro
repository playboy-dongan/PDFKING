---
import ToolPage from '../../components/pages/ToolPage.astro';
import { defaultLocale, locales, getTools } from '../../data/tools';

export const prerender = true;

export function getStaticPaths() {
	return locales
		.filter((locale) => locale.code !== defaultLocale)
		.flatMap((locale) =>
			getTools(locale.code).map((tool) => ({
				params: { locale: locale.code, slug: tool.slug },
				props: { locale: locale.code, slug: tool.slug },
			})),
		);
}

const { locale, slug } = Astro.props;
---

<ToolPage locale={locale} slug={slug} />
