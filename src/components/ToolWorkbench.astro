---
import type { ToolDefinition } from '../data/tools';

const { tool } = Astro.props as { tool: ToolDefinition };

const isZh = tool.locale === 'zh-cn';
const acceptHint = tool.acceptHint[tool.locale];
const copy = isZh
	? {
			eyebrow: '在线处理',
			title: tool.actionLabel,
			description: acceptHint,
			uploadLabel: '上传文件',
			uploadHint: tool.allowMultiple ? '支持一次选择多个文件' : '当前工具一次处理一个文件',
			acceptLabel: '支持格式',
			engineLabel: '开源引擎',
			engineValue: tool.engineSummary,
			previewTitle: '文件预览',
			previewBody: '上传后会在这里显示首页预览、文档摘要或图像缩略图。',
			previewWaiting: '等待文件',
			resultsTitle: '处理结果',
			resultsBody: '处理完成后，这里会出现下载按钮和结果摘要。',
			statusTitle: '当前状态',
			statusValue: '等待上传',
			runLabel: tool.actionLabel,
			multiLabel: '多文件',
			singleLabel: '单文件',
			rangeLabel: '页码范围',
			rangeHint: '示例：1-2,4,7-9',
			qualityLabel: '压缩质量',
			qualityHint: '数值越低，体积越小，画质也会更低。',
			watermarkTextLabel: '水印文字',
			watermarkOpacityLabel: '水印透明度',
			rotationLabel: '旋转角度',
			openPasswordLabel: '打开密码',
			ownerPasswordLabel: '所有者密码',
			unlockPasswordLabel: '当前密码',
			ocrFormatLabel: 'OCR 输出格式',
			ocrDocx: 'DOCX 文档',
			ocrTxt: 'TXT 文本',
		}
	: {
			eyebrow: 'Online processing',
			title: tool.actionLabel,
			description: acceptHint,
			uploadLabel: 'Upload files',
			uploadHint: tool.allowMultiple ? 'Multiple files are supported in one run' : 'This tool processes one file at a time',
			acceptLabel: 'Accepted formats',
			engineLabel: 'Open-source engine',
			engineValue: tool.engineSummary,
			previewTitle: 'File preview',
			previewBody: 'The first page preview, document summary, or image thumbnail appears here after upload.',
			previewWaiting: 'Waiting for file',
			resultsTitle: 'Results',
			resultsBody: 'Download buttons and result summaries will appear here after processing.',
			statusTitle: 'Status',
			statusValue: 'Waiting for upload',
			runLabel: tool.actionLabel,
			multiLabel: 'multi',
			singleLabel: 'single',
			rangeLabel: 'Page ranges',
			rangeHint: 'Example: 1-2,4,7-9',
			qualityLabel: 'Compression quality',
			qualityHint: 'Lower values reduce size more aggressively and lower visual quality.',
			watermarkTextLabel: 'Watermark text',
			watermarkOpacityLabel: 'Watermark opacity',
			rotationLabel: 'Rotation angle',
			openPasswordLabel: 'Open password',
			ownerPasswordLabel: 'Owner password',
			unlockPasswordLabel: 'Current password',
			ocrFormatLabel: 'OCR export format',
			ocrDocx: 'DOCX document',
			ocrTxt: 'TXT text',
		};
---

<section
	data-tool-workbench
	data-tool={JSON.stringify({
		locale: tool.locale,
		slug: tool.slug,
		name: tool.name,
		actionLabel: tool.actionLabel,
	})}
	class="overflow-hidden rounded-3xl border border-gray-200 bg-white shadow-2xl shadow-blue-100"
>
	<div class="grid lg:grid-cols-[0.9fr_1.1fr]">
		<div class="border-b border-gray-200 bg-gray-50 p-6 lg:border-b-0 lg:border-r lg:p-8">
			<p class="mb-3 text-sm font-semibold uppercase tracking-[0.24em] text-blue-700">{copy.eyebrow}</p>
			<h2 class="mb-3 text-3xl font-extrabold tracking-tight text-gray-900">{copy.title}</h2>
			<p class="mb-8 text-sm leading-7 text-gray-500">{copy.description}</p>

			<div class="space-y-5">
				<div class="rounded-2xl border-2 border-dashed border-blue-200 bg-white p-5">
					<div class="mb-4 flex items-start justify-between gap-4">
						<div>
							<p class="text-base font-semibold text-gray-900">{copy.uploadLabel}</p>
							<p class="mt-1 text-sm text-gray-500">{copy.uploadHint}</p>
						</div>
						<span class="rounded-full bg-blue-100 px-3 py-1 text-xs font-semibold text-blue-700">
							{tool.allowMultiple ? copy.multiLabel : copy.singleLabel}
						</span>
					</div>
					<input
						data-role="file-input"
						type="file"
						accept={tool.accept}
						multiple={tool.allowMultiple}
						class="block w-full cursor-pointer rounded-lg border border-gray-300 bg-gray-50 text-sm text-gray-900 file:mr-4 file:border-0 file:bg-blue-700 file:px-4 file:py-3 file:text-sm file:font-medium file:text-white hover:file:bg-blue-800 focus:outline-none"
					/>
				</div>

				<div class="grid gap-4 sm:grid-cols-2">
					<div class="rounded-xl border border-gray-200 bg-white p-4">
						<p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-gray-400">{copy.acceptLabel}</p>
						<p class="text-sm font-medium text-gray-900">{tool.accept.replaceAll(',', ' / ')}</p>
					</div>
					<div class="rounded-xl border border-gray-200 bg-white p-4">
						<p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-gray-400">{copy.engineLabel}</p>
						<p class="text-sm leading-6 text-gray-600">{copy.engineValue}</p>
					</div>
				</div>

				{tool.slug === 'split-pdf' && (
					<label class="block rounded-2xl border border-gray-200 bg-white p-5">
						<span class="text-sm font-semibold text-gray-900">{copy.rangeLabel}</span>
						<input data-role="ranges" type="text" value="1-2,4" class="mt-3 block w-full rounded-lg border border-gray-300 bg-gray-50 p-3 text-sm text-gray-900 focus:border-blue-600 focus:ring-blue-600" />
						<span class="mt-2 block text-xs leading-6 text-gray-500">{copy.rangeHint}</span>
					</label>
				)}

				{tool.slug === 'compress-pdf' && (
					<label class="block rounded-2xl border border-gray-200 bg-white p-5">
						<span class="text-sm font-semibold text-gray-900">{copy.qualityLabel}</span>
						<input data-role="quality" type="range" min="0.35" max="0.9" step="0.05" value="0.7" class="mt-4 block w-full accent-blue-700" />
						<span class="mt-2 block text-xs leading-6 text-gray-500">{copy.qualityHint}</span>
					</label>
				)}

				{tool.slug === 'pdf-watermark' && (
					<div class="grid gap-4 rounded-2xl border border-gray-200 bg-white p-5">
						<label class="block">
							<span class="text-sm font-semibold text-gray-900">{copy.watermarkTextLabel}</span>
							<input data-role="watermark-text" type="text" value="PDFKING" class="mt-3 block w-full rounded-lg border border-gray-300 bg-gray-50 p-3 text-sm text-gray-900 focus:border-blue-600 focus:ring-blue-600" />
						</label>
						<label class="block">
							<span class="text-sm font-semibold text-gray-900">{copy.watermarkOpacityLabel}</span>
							<input data-role="watermark-opacity" type="range" min="0.08" max="0.45" step="0.02" value="0.18" class="mt-3 block w-full accent-blue-700" />
						</label>
					</div>
				)}

				{tool.slug === 'rotate-pdf' && (
					<label class="block rounded-2xl border border-gray-200 bg-white p-5">
						<span class="text-sm font-semibold text-gray-900">{copy.rotationLabel}</span>
						<select data-role="rotation" class="mt-3 block w-full rounded-lg border border-gray-300 bg-gray-50 p-3 text-sm text-gray-900 focus:border-blue-600 focus:ring-blue-600">
							<option value="90">90 deg</option>
							<option value="180">180 deg</option>
							<option value="270">270 deg</option>
						</select>
					</label>
				)}

				{tool.slug === 'protect-pdf' && (
					<div class="grid gap-4 rounded-2xl border border-gray-200 bg-white p-5">
						<label class="block">
							<span class="text-sm font-semibold text-gray-900">{copy.openPasswordLabel}</span>
							<input data-role="user-password" type="password" class="mt-3 block w-full rounded-lg border border-gray-300 bg-gray-50 p-3 text-sm text-gray-900 focus:border-blue-600 focus:ring-blue-600" />
						</label>
						<label class="block">
							<span class="text-sm font-semibold text-gray-900">{copy.ownerPasswordLabel}</span>
							<input data-role="owner-password" type="password" class="mt-3 block w-full rounded-lg border border-gray-300 bg-gray-50 p-3 text-sm text-gray-900 focus:border-blue-600 focus:ring-blue-600" />
						</label>
					</div>
				)}

				{tool.slug === 'unlock-pdf' && (
					<label class="block rounded-2xl border border-gray-200 bg-white p-5">
						<span class="text-sm font-semibold text-gray-900">{copy.unlockPasswordLabel}</span>
						<input data-role="unlock-password" type="password" class="mt-3 block w-full rounded-lg border border-gray-300 bg-gray-50 p-3 text-sm text-gray-900 focus:border-blue-600 focus:ring-blue-600" />
					</label>
				)}

				{tool.slug === 'ocr-pdf' && (
					<label class="block rounded-2xl border border-gray-200 bg-white p-5">
						<span class="text-sm font-semibold text-gray-900">{copy.ocrFormatLabel}</span>
						<select data-role="ocr-format" class="mt-3 block w-full rounded-lg border border-gray-300 bg-gray-50 p-3 text-sm text-gray-900 focus:border-blue-600 focus:ring-blue-600">
							<option value="docx">{copy.ocrDocx}</option>
							<option value="txt">{copy.ocrTxt}</option>
						</select>
					</label>
				)}

				<button data-role="run-button" type="button" class="inline-flex w-full items-center justify-center rounded-lg bg-blue-700 px-5 py-3.5 text-base font-medium text-white hover:bg-blue-800 focus:outline-none focus:ring-4 focus:ring-blue-300">
					{copy.runLabel}
				</button>
			</div>
		</div>

		<div class="p-6 lg:p-8">
			<div class="mb-5 flex items-center justify-between">
				<div>
					<p class="text-base font-semibold text-gray-900">{copy.previewTitle}</p>
					<p class="mt-1 text-sm text-gray-500">{copy.previewBody}</p>
				</div>
				<span data-role="preview-label" class="rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold text-gray-600">{copy.previewWaiting}</span>
			</div>
			<div data-role="preview" class="flex min-h-80 items-center justify-center rounded-2xl border border-dashed border-gray-300 bg-gray-50 p-6 text-center text-sm leading-7 text-gray-500">
				{copy.previewBody}
			</div>

			<div class="mt-6 rounded-2xl border border-gray-200 bg-white p-5">
				<div class="mb-4 flex items-center justify-between gap-4">
					<div>
						<p class="text-base font-semibold text-gray-900">{copy.statusTitle}</p>
						<p class="mt-1 text-sm text-gray-500">{copy.resultsBody}</p>
					</div>
					<span data-role="status" class="rounded-full bg-green-100 px-3 py-1 text-xs font-semibold text-green-700">{copy.statusValue}</span>
				</div>
				<div data-role="results" class="grid gap-3">
					<div class="rounded-xl border border-dashed border-gray-300 bg-gray-50 p-5 text-sm leading-7 text-gray-500">
						<p class="font-semibold text-gray-900">{copy.resultsTitle}</p>
						<p class="mt-1">{copy.resultsBody}</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<script type="module">
	import { initToolWorkbench } from '../scripts/tool-workbench';

	initToolWorkbench();
</script>
