---
import type { ToolDefinition } from '../data/tools';

const { tool } = Astro.props as { tool: ToolDefinition };

const isZh = tool.locale === 'zh-cn';
const acceptHint = tool.acceptHint[tool.locale];
const copy = isZh
	? {
			title: tool.actionLabel,
			description: acceptHint,
			uploadLabel: tool.allowMultiple ? '把 PDF 文件拖到这里' : '把文件拖到这里',
			uploadHint: '拖放文件，或点击选择。文件在你的设备上处理。',
			selectLabel: tool.allowMultiple ? '选择 PDF 文件' : '选择文件',
			acceptLabel: '支持格式',
			engineLabel: '处理方式',
			engineValue: tool.engineSummary,
			previewTitle: '文件预览',
			previewBody: '上传后会在这里显示首页预览、文档摘要或图像缩略图。',
			previewWaiting: '等待文件',
			resultsTitle: '处理结果',
			resultsBody: '处理完成后，这里会出现下载按钮和结果摘要。',
			statusValue: '等待上传',
			runLabel: tool.actionLabel,
			rangeLabel: '页码范围',
			rangeHint: '示例：1-2,4,7-9',
			qualityLabel: '压缩质量',
			qualityHint: '数值越低，体积越小，画质也会更低。',
			watermarkTextLabel: '水印文字',
			watermarkOpacityLabel: '水印透明度',
			rotationLabel: '旋转角度',
			openPasswordLabel: '打开密码',
			ownerPasswordLabel: '所有者密码',
			unlockPasswordLabel: '当前密码',
			ocrFormatLabel: 'OCR 输出格式',
			ocrDocx: 'DOCX 文档',
			ocrTxt: 'TXT 文本',
		}
	: {
			title: tool.actionLabel,
			description: acceptHint,
			uploadLabel: tool.allowMultiple ? 'Drop your PDFs here' : 'Drop your file here',
			uploadHint: 'Drag and drop your files here, or click to select. Privately processed on your device.',
			selectLabel: tool.allowMultiple ? 'Select PDF files' : 'Select file',
			acceptLabel: 'Accepted formats',
			engineLabel: 'Processing mode',
			engineValue: tool.engineSummary,
			previewTitle: 'File preview',
			previewBody: 'A first-page preview, document summary, or image thumbnail appears after upload.',
			previewWaiting: 'Waiting for file',
			resultsTitle: 'Processing result',
			resultsBody: 'Download buttons and a result summary appear after processing.',
			statusValue: 'Waiting for upload',
			runLabel: tool.actionLabel,
			rangeLabel: 'Page ranges',
			rangeHint: 'Example: 1-2,4,7-9',
			qualityLabel: 'Compression quality',
			qualityHint: 'Lower values reduce size more aggressively and lower visual quality.',
			watermarkTextLabel: 'Watermark text',
			watermarkOpacityLabel: 'Watermark opacity',
			rotationLabel: 'Rotation angle',
			openPasswordLabel: 'Open password',
			ownerPasswordLabel: 'Owner password',
			unlockPasswordLabel: 'Current password',
			ocrFormatLabel: 'OCR export format',
			ocrDocx: 'DOCX document',
			ocrTxt: 'TXT text',
		};
---

<section
	data-tool-workbench
	data-tool={JSON.stringify({
		locale: tool.locale,
		slug: tool.slug,
		name: tool.name,
		actionLabel: tool.actionLabel,
	})}
	class="space-y-4"
>
	<label class="relative block rounded-2xl border-2 border-dashed border-[var(--border)] bg-[var(--muted)]/30 transition-colors hover:bg-[var(--muted)]/10">
		<input
			data-role="file-input"
			type="file"
			accept={tool.accept}
			multiple={tool.allowMultiple}
			class="sr-only"
		/>
		<div class="flex cursor-pointer flex-col items-center justify-center px-4 py-20 text-center">
			<div class="mb-6 flex size-16 items-center justify-center rounded-2xl bg-[var(--primary)]/10 text-[var(--primary)] shadow-sm">
				<svg class="size-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 16V4m0 0 4 4m-4-4-4 4M4 16.5V18a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-1.5" /></svg>
			</div>
			<h3 class="mb-2 text-xl font-bold tracking-tight text-[var(--foreground)]">{copy.uploadLabel}</h3>
			<p class="mb-8 max-w-sm text-sm leading-relaxed text-[var(--muted-foreground)]">{copy.uploadHint}</p>
			<span class="inline-flex h-9 items-center justify-center gap-2 rounded-full border border-transparent bg-[var(--primary)] px-8 text-sm font-medium text-[var(--primary-foreground)] shadow-lg shadow-[var(--primary)]/20 transition-all hover:scale-105">
				{copy.selectLabel}
			</span>
		</div>
	</label>

	<div class="grid gap-4 md:grid-cols-2">
		<div class="rounded-2xl border border-[var(--border)] bg-[var(--card)] p-5 shadow-sm">
			<p class="mb-2 text-xs font-medium uppercase text-[var(--muted-foreground)]">{copy.acceptLabel}</p>
			<p class="text-sm font-medium leading-6 text-[var(--foreground)]">{tool.accept.replaceAll(',', ' / ')}</p>
		</div>
		<div class="rounded-2xl border border-[var(--border)] bg-[var(--card)] p-5 shadow-sm">
			<p class="mb-2 text-xs font-medium uppercase text-[var(--muted-foreground)]">{copy.engineLabel}</p>
			<p class="text-sm leading-6 text-[var(--muted-foreground)]">{copy.engineValue}</p>
		</div>
	</div>

	<div class="space-y-3">
		{tool.slug === 'split-pdf' && (
			<label class="block rounded-2xl border border-[var(--border)] bg-[var(--card)] p-5 shadow-sm">
				<span class="text-sm font-semibold text-[var(--foreground)]">{copy.rangeLabel}</span>
				<input data-role="ranges" type="text" value="1-2,4" class="mt-3 block w-full rounded-md border border-[var(--border)] bg-transparent p-3 text-sm text-[var(--foreground)] outline-none focus:border-[var(--ring)]" />
				<span class="mt-2 block text-xs leading-5 text-[var(--muted-foreground)]">{copy.rangeHint}</span>
			</label>
		)}

		{tool.slug === 'compress-pdf' && (
			<label class="block rounded-2xl border border-[var(--border)] bg-[var(--card)] p-5 shadow-sm">
				<span class="text-sm font-semibold text-[var(--foreground)]">{copy.qualityLabel}</span>
				<input data-role="quality" type="range" min="0.35" max="0.9" step="0.05" value="0.7" class="mt-4 block w-full accent-[var(--primary)]" />
				<span class="mt-2 block text-xs leading-5 text-[var(--muted-foreground)]">{copy.qualityHint}</span>
			</label>
		)}

		{tool.slug === 'pdf-watermark' && (
			<div class="grid gap-3 rounded-2xl border border-[var(--border)] bg-[var(--card)] p-5 shadow-sm sm:grid-cols-2">
				<label class="block">
					<span class="text-sm font-semibold text-[var(--foreground)]">{copy.watermarkTextLabel}</span>
					<input data-role="watermark-text" type="text" value="PDFKING" class="mt-3 block w-full rounded-md border border-[var(--border)] bg-transparent p-3 text-sm text-[var(--foreground)] outline-none focus:border-[var(--ring)]" />
				</label>
				<label class="block">
					<span class="text-sm font-semibold text-[var(--foreground)]">{copy.watermarkOpacityLabel}</span>
					<input data-role="watermark-opacity" type="range" min="0.08" max="0.45" step="0.02" value="0.18" class="mt-5 block w-full accent-[var(--primary)]" />
				</label>
			</div>
		)}

		{tool.slug === 'rotate-pdf' && (
			<label class="block rounded-2xl border border-[var(--border)] bg-[var(--card)] p-5 shadow-sm">
				<span class="text-sm font-semibold text-[var(--foreground)]">{copy.rotationLabel}</span>
				<select data-role="rotation" class="mt-3 block w-full rounded-md border border-[var(--border)] bg-transparent p-3 text-sm text-[var(--foreground)] outline-none focus:border-[var(--ring)]">
					<option value="90">90 deg</option>
					<option value="180">180 deg</option>
					<option value="270">270 deg</option>
				</select>
			</label>
		)}

		{tool.slug === 'protect-pdf' && (
			<div class="grid gap-3 rounded-2xl border border-[var(--border)] bg-[var(--card)] p-5 shadow-sm sm:grid-cols-2">
				<label class="block">
					<span class="text-sm font-semibold text-[var(--foreground)]">{copy.openPasswordLabel}</span>
					<input data-role="user-password" type="password" class="mt-3 block w-full rounded-md border border-[var(--border)] bg-transparent p-3 text-sm text-[var(--foreground)] outline-none focus:border-[var(--ring)]" />
				</label>
				<label class="block">
					<span class="text-sm font-semibold text-[var(--foreground)]">{copy.ownerPasswordLabel}</span>
					<input data-role="owner-password" type="password" class="mt-3 block w-full rounded-md border border-[var(--border)] bg-transparent p-3 text-sm text-[var(--foreground)] outline-none focus:border-[var(--ring)]" />
				</label>
			</div>
		)}

		{tool.slug === 'unlock-pdf' && (
			<label class="block rounded-2xl border border-[var(--border)] bg-[var(--card)] p-5 shadow-sm">
				<span class="text-sm font-semibold text-[var(--foreground)]">{copy.unlockPasswordLabel}</span>
				<input data-role="unlock-password" type="password" class="mt-3 block w-full rounded-md border border-[var(--border)] bg-transparent p-3 text-sm text-[var(--foreground)] outline-none focus:border-[var(--ring)]" />
			</label>
		)}

		{tool.slug === 'ocr-pdf' && (
			<label class="block rounded-2xl border border-[var(--border)] bg-[var(--card)] p-5 shadow-sm">
				<span class="text-sm font-semibold text-[var(--foreground)]">{copy.ocrFormatLabel}</span>
				<select data-role="ocr-format" class="mt-3 block w-full rounded-md border border-[var(--border)] bg-transparent p-3 text-sm text-[var(--foreground)] outline-none focus:border-[var(--ring)]">
					<option value="docx">{copy.ocrDocx}</option>
					<option value="txt">{copy.ocrTxt}</option>
				</select>
			</label>
		)}
	</div>

	<button data-role="run-button" type="button" class="inline-flex h-10 w-full items-center justify-center rounded-full bg-[var(--primary)] px-8 text-sm font-medium text-[var(--primary-foreground)] shadow-lg shadow-[var(--primary)]/20 transition-all hover:scale-[1.01]">
		{copy.runLabel}
	</button>

	<div class="grid gap-4 lg:grid-cols-2">
		<div class="rounded-2xl border border-[var(--border)] bg-[var(--card)] p-5 shadow-sm">
			<div class="mb-3 flex items-center justify-between gap-3">
				<p class="text-sm font-semibold text-[var(--foreground)]">{copy.previewTitle}</p>
				<span data-role="preview-label" class="rounded-full bg-[var(--muted)] px-2.5 py-1 text-xs font-medium text-[var(--muted-foreground)]">{copy.previewWaiting}</span>
			</div>
			<div data-role="preview" class="flex min-h-44 items-center justify-center rounded-xl border border-dashed border-[var(--border)] bg-[var(--background)] p-4 text-center text-sm leading-6 text-[var(--muted-foreground)]">
				{copy.previewBody}
			</div>
		</div>

		<div class="rounded-2xl border border-[var(--border)] bg-[var(--card)] p-5 shadow-sm">
			<div class="mb-3 flex items-center justify-between gap-3">
				<p class="text-sm font-semibold text-[var(--foreground)]">{copy.resultsTitle}</p>
				<span data-role="status" class="rounded-full bg-[var(--muted)] px-2.5 py-1 text-xs font-medium text-[var(--muted-foreground)]">{copy.statusValue}</span>
			</div>
			<div data-role="results" class="grid gap-3">
				<div class="rounded-xl border border-dashed border-[var(--border)] bg-[var(--background)] p-4 text-sm leading-6 text-[var(--muted-foreground)]">
					<p>{copy.resultsBody}</p>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	import { initToolWorkbench } from '../scripts/tool-workbench.ts';

	initToolWorkbench();
</script>
