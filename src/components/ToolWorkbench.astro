---
import type { ToolDefinition } from '../data/tools';

const { tool } = Astro.props as { tool: ToolDefinition };

const isZh = tool.locale === 'zh-cn';
const acceptHint = tool.acceptHint[tool.locale];
const copy = isZh
	? {
			title: tool.actionLabel,
			description: acceptHint,
			uploadLabel: '选择文件',
			uploadHint: tool.allowMultiple ? '支持一次选择多个文件' : '当前工具一次处理一个文件',
			acceptLabel: '支持格式',
			engineLabel: '处理方式',
			engineValue: tool.engineSummary,
			previewTitle: '文件预览',
			previewBody: '上传后会在这里显示首页预览、文档摘要或图像缩略图。',
			previewWaiting: '等待文件',
			resultsTitle: '处理结果',
			resultsBody: '处理完成后，这里会出现下载按钮和结果摘要。',
			statusValue: '等待上传',
			runLabel: tool.actionLabel,
			multiLabel: '多文件',
			singleLabel: '单文件',
			rangeLabel: '页码范围',
			rangeHint: '示例：1-2,4,7-9',
			qualityLabel: '压缩质量',
			qualityHint: '数值越低，体积越小，画质也会更低。',
			watermarkTextLabel: '水印文字',
			watermarkOpacityLabel: '水印透明度',
			rotationLabel: '旋转角度',
			openPasswordLabel: '打开密码',
			ownerPasswordLabel: '所有者密码',
			unlockPasswordLabel: '当前密码',
			ocrFormatLabel: 'OCR 输出格式',
			ocrDocx: 'DOCX 文档',
			ocrTxt: 'TXT 文本',
		}
	: {
			title: tool.actionLabel,
			description: acceptHint,
			uploadLabel: 'Choose files',
			uploadHint: tool.allowMultiple ? 'Multiple files are supported in one run' : 'This tool processes one file at a time',
			acceptLabel: 'Accepted formats',
			engineLabel: 'Processing mode',
			engineValue: tool.engineSummary,
			previewTitle: 'File preview',
			previewBody: 'A first-page preview, document summary, or image thumbnail appears after upload.',
			previewWaiting: 'Waiting for file',
			resultsTitle: 'Processing result',
			resultsBody: 'Download buttons and a result summary appear after processing.',
			statusValue: 'Waiting for upload',
			runLabel: tool.actionLabel,
			multiLabel: 'multi-file',
			singleLabel: 'single-file',
			rangeLabel: 'Page ranges',
			rangeHint: 'Example: 1-2,4,7-9',
			qualityLabel: 'Compression quality',
			qualityHint: 'Lower values reduce size more aggressively and lower visual quality.',
			watermarkTextLabel: 'Watermark text',
			watermarkOpacityLabel: 'Watermark opacity',
			rotationLabel: 'Rotation angle',
			openPasswordLabel: 'Open password',
			ownerPasswordLabel: 'Owner password',
			unlockPasswordLabel: 'Current password',
			ocrFormatLabel: 'OCR export format',
			ocrDocx: 'DOCX document',
			ocrTxt: 'TXT text',
		};
---

<section
	data-tool-workbench
	data-tool={JSON.stringify({
		locale: tool.locale,
		slug: tool.slug,
		name: tool.name,
		actionLabel: tool.actionLabel,
	})}
	class="rounded-3xl border border-[var(--line)] bg-white p-4 shadow-[0_24px_70px_-54px_rgba(23,20,17,0.65)] sm:p-5"
>
	<div class="flex items-start justify-between gap-4">
		<div>
			<p class="text-lg font-semibold tracking-tight text-[var(--ink)]">{copy.title}</p>
			<p class="mt-2 text-sm leading-6 text-[var(--muted)]">{copy.description}</p>
		</div>
		<span class="rounded-md bg-[var(--accent-soft)] px-2.5 py-1 text-xs font-semibold text-[var(--accent-ink)]">
			{tool.allowMultiple ? copy.multiLabel : copy.singleLabel}
		</span>
	</div>

	<div class="mt-5 rounded-2xl border border-dashed border-[var(--line-strong)] bg-[var(--paper)] p-4">
		<div class="flex items-center gap-3">
			<div class="flex size-11 shrink-0 items-center justify-center rounded-xl bg-[var(--ink)] text-white">
				<svg class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 16V4m0 0 4 4m-4-4-4 4M4 16.5V18a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-1.5" /></svg>
			</div>
			<div>
				<p class="text-sm font-semibold text-[var(--ink)]">{copy.uploadLabel}</p>
				<p class="mt-1 text-xs leading-5 text-[var(--muted)]">{copy.uploadHint}</p>
			</div>
		</div>
		<input
			data-role="file-input"
			type="file"
			accept={tool.accept}
			multiple={tool.allowMultiple}
			class="mt-4 block w-full cursor-pointer rounded-md border border-[var(--line)] bg-white text-sm text-[var(--muted)] shadow-sm file:mr-4 file:border-0 file:bg-[var(--ink)] file:px-4 file:py-3 file:text-sm file:font-semibold file:text-white hover:file:bg-[#2a251f] focus:outline-none"
		/>
	</div>

	<div class="mt-4 grid gap-3 sm:grid-cols-2">
		<div class="rounded-2xl border border-[var(--line)] bg-[var(--paper)] p-4">
			<p class="mb-2 text-xs font-semibold uppercase tracking-[0.18em] text-[var(--faint)]">{copy.acceptLabel}</p>
			<p class="text-sm font-medium leading-6 text-[var(--ink)]">{tool.accept.replaceAll(',', ' / ')}</p>
		</div>
		<div class="rounded-2xl border border-[var(--line)] bg-[var(--paper)] p-4">
			<p class="mb-2 text-xs font-semibold uppercase tracking-[0.18em] text-[var(--faint)]">{copy.engineLabel}</p>
			<p class="text-sm leading-6 text-[var(--muted)]">{copy.engineValue}</p>
		</div>
	</div>

	<div class="mt-4 space-y-3">
		{tool.slug === 'split-pdf' && (
			<label class="block rounded-2xl border border-[var(--line)] bg-white p-4">
				<span class="text-sm font-semibold text-[var(--ink)]">{copy.rangeLabel}</span>
				<input data-role="ranges" type="text" value="1-2,4" class="mt-3 block w-full rounded-md border border-[var(--line)] bg-[var(--paper)] p-3 text-sm text-[var(--ink)] focus:border-[var(--line-strong)] focus:outline-none" />
				<span class="mt-2 block text-xs leading-5 text-[var(--muted)]">{copy.rangeHint}</span>
			</label>
		)}

		{tool.slug === 'compress-pdf' && (
			<label class="block rounded-2xl border border-[var(--line)] bg-white p-4">
				<span class="text-sm font-semibold text-[var(--ink)]">{copy.qualityLabel}</span>
				<input data-role="quality" type="range" min="0.35" max="0.9" step="0.05" value="0.7" class="mt-4 block w-full accent-[var(--ink)]" />
				<span class="mt-2 block text-xs leading-5 text-[var(--muted)]">{copy.qualityHint}</span>
			</label>
		)}

		{tool.slug === 'pdf-watermark' && (
			<div class="grid gap-3 rounded-2xl border border-[var(--line)] bg-white p-4 sm:grid-cols-2">
				<label class="block">
					<span class="text-sm font-semibold text-[var(--ink)]">{copy.watermarkTextLabel}</span>
					<input data-role="watermark-text" type="text" value="PDFKING" class="mt-3 block w-full rounded-md border border-[var(--line)] bg-[var(--paper)] p-3 text-sm text-[var(--ink)] focus:border-[var(--line-strong)] focus:outline-none" />
				</label>
				<label class="block">
					<span class="text-sm font-semibold text-[var(--ink)]">{copy.watermarkOpacityLabel}</span>
					<input data-role="watermark-opacity" type="range" min="0.08" max="0.45" step="0.02" value="0.18" class="mt-5 block w-full accent-[var(--ink)]" />
				</label>
			</div>
		)}

		{tool.slug === 'rotate-pdf' && (
			<label class="block rounded-2xl border border-[var(--line)] bg-white p-4">
				<span class="text-sm font-semibold text-[var(--ink)]">{copy.rotationLabel}</span>
				<select data-role="rotation" class="mt-3 block w-full rounded-md border border-[var(--line)] bg-[var(--paper)] p-3 text-sm text-[var(--ink)] focus:border-[var(--line-strong)] focus:outline-none">
					<option value="90">90 deg</option>
					<option value="180">180 deg</option>
					<option value="270">270 deg</option>
				</select>
			</label>
		)}

		{tool.slug === 'protect-pdf' && (
			<div class="grid gap-3 rounded-2xl border border-[var(--line)] bg-white p-4 sm:grid-cols-2">
				<label class="block">
					<span class="text-sm font-semibold text-[var(--ink)]">{copy.openPasswordLabel}</span>
					<input data-role="user-password" type="password" class="mt-3 block w-full rounded-md border border-[var(--line)] bg-[var(--paper)] p-3 text-sm text-[var(--ink)] focus:border-[var(--line-strong)] focus:outline-none" />
				</label>
				<label class="block">
					<span class="text-sm font-semibold text-[var(--ink)]">{copy.ownerPasswordLabel}</span>
					<input data-role="owner-password" type="password" class="mt-3 block w-full rounded-md border border-[var(--line)] bg-[var(--paper)] p-3 text-sm text-[var(--ink)] focus:border-[var(--line-strong)] focus:outline-none" />
				</label>
			</div>
		)}

		{tool.slug === 'unlock-pdf' && (
			<label class="block rounded-2xl border border-[var(--line)] bg-white p-4">
				<span class="text-sm font-semibold text-[var(--ink)]">{copy.unlockPasswordLabel}</span>
				<input data-role="unlock-password" type="password" class="mt-3 block w-full rounded-md border border-[var(--line)] bg-[var(--paper)] p-3 text-sm text-[var(--ink)] focus:border-[var(--line-strong)] focus:outline-none" />
			</label>
		)}

		{tool.slug === 'ocr-pdf' && (
			<label class="block rounded-2xl border border-[var(--line)] bg-white p-4">
				<span class="text-sm font-semibold text-[var(--ink)]">{copy.ocrFormatLabel}</span>
				<select data-role="ocr-format" class="mt-3 block w-full rounded-md border border-[var(--line)] bg-[var(--paper)] p-3 text-sm text-[var(--ink)] focus:border-[var(--line-strong)] focus:outline-none">
					<option value="docx">{copy.ocrDocx}</option>
					<option value="txt">{copy.ocrTxt}</option>
				</select>
			</label>
		)}
	</div>

	<button data-role="run-button" type="button" class="mt-4 inline-flex w-full items-center justify-center rounded-md bg-[var(--ink)] px-5 py-3.5 text-sm font-semibold text-white shadow-[0_16px_40px_-30px_rgba(23,20,17,0.75)] transition hover:bg-[#2a251f] focus:outline-none">
		{copy.runLabel}
	</button>

	<div class="mt-4 grid gap-3">
		<div class="rounded-2xl border border-[var(--line)] bg-[var(--paper)] p-4">
			<div class="mb-3 flex items-center justify-between gap-3">
				<p class="text-sm font-semibold text-[var(--ink)]">{copy.previewTitle}</p>
				<span data-role="preview-label" class="rounded-md bg-white px-2.5 py-1 text-xs font-medium text-[var(--muted)] shadow-sm">{copy.previewWaiting}</span>
			</div>
			<div data-role="preview" class="flex min-h-36 items-center justify-center rounded-xl border border-dashed border-[var(--line-strong)] bg-white p-4 text-center text-sm leading-6 text-[var(--muted)]">
				{copy.previewBody}
			</div>
		</div>

		<div class="rounded-2xl border border-[var(--line)] bg-[var(--paper)] p-4">
			<div class="mb-3 flex items-center justify-between gap-3">
				<p class="text-sm font-semibold text-[var(--ink)]">{copy.resultsTitle}</p>
				<span data-role="status" class="rounded-md bg-[var(--accent-soft)] px-2.5 py-1 text-xs font-semibold text-[var(--accent-ink)]">{copy.statusValue}</span>
			</div>
			<div data-role="results" class="grid gap-3">
				<div class="rounded-xl border border-dashed border-[var(--line-strong)] bg-white p-4 text-sm leading-6 text-[var(--muted)]">
					<p>{copy.resultsBody}</p>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	import { initToolWorkbench } from '../scripts/tool-workbench.ts';

	initToolWorkbench();
</script>
