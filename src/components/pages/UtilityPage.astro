---
import LanguageSwitcher from '../LanguageSwitcher.astro';
import Layout from '../../layouts/Layout.astro';
import { getLocaleMeta, getLocalePath, type Locale } from '../../data/tools';

const { locale, kind } = Astro.props as { locale: Locale; kind: 'help' | 'settings' };
const localeMeta = getLocaleMeta(locale);
const routePrefix = locale === 'zh-cn' ? '' : `/${locale}`;
const copy = locale === 'zh-cn'
	? {
			help: '帮助',
			settings: '设置',
			home: '首页',
			tagline: '本地优先 PDF 工具',
			title: kind === 'help' ? '帮助' : '设置',
			description: kind === 'help' ? '了解 PDFKING 的上传、处理和下载流程。' : 'PDFKING 暂时不需要账号设置，所有核心工具都可直接使用。',
			cards: kind === 'help'
				? [
						['上传文件', '打开任意 PDF 工具页，选择文件后会先生成预览。'],
						['处理文件', '点击处理按钮后，浏览器会调用对应开源库生成结果。'],
						['下载结果', '处理完成后，结果区会显示可下载文件。'],
					]
				: [
						['语言', '站点支持简体中文和 English 路由。'],
						['隐私', '核心流程优先在浏览器侧处理，尽量减少服务器依赖。'],
						['广告', '后续可接入 AdSense，但不影响工具使用。'],
					],
		}
	: {
			help: 'Help',
			settings: 'Settings',
			home: 'Home',
			tagline: 'Local-first PDF tools',
			title: kind === 'help' ? 'Help' : 'Settings',
			description: kind === 'help' ? 'Learn how PDFKING upload, processing, and download flows work.' : 'PDFKING does not require account settings yet. Core tools are ready to use directly.',
			cards: kind === 'help'
				? [
						['Upload files', 'Open any PDF tool page and choose files to generate a preview.'],
						['Process files', 'Click the run button and the browser calls the matching open-source engine.'],
						['Download results', 'After processing, the result area exposes downloadable files.'],
					]
				: [
						['Language', 'The site supports Simplified Chinese and English routes.'],
						['Privacy', 'Core workflows run browser-first to reduce server dependency.'],
						['Ads', 'AdSense can be added later without blocking the tools.'],
					],
		};
---

<Layout title={`PDFKING ${copy.title}`} description={copy.description} lang={localeMeta.htmlLang}>
	<div class="flex min-h-svh w-full bg-[var(--paper)]">
		<aside class="sticky top-0 hidden h-svh w-64 shrink-0 border-r border-[var(--line)] bg-[var(--ink)] text-white md:flex md:flex-col">
			<div class="flex h-16 items-center gap-3 border-b border-white/10 px-4">
				<img src="/pdfking-logo.svg" alt="PDFKING logo" class="size-10 rounded-md bg-white p-1" />
				<div class="min-w-0">
					<p class="truncate text-sm font-semibold">PDFKING</p>
					<p class="truncate text-xs text-white/55">{copy.tagline}</p>
				</div>
			</div>
			<nav class="flex min-h-0 flex-1 flex-col gap-5 overflow-y-auto p-4 text-sm">
				<div>
					<p class="mb-2 px-2 text-xs font-semibold uppercase tracking-[0.18em] text-white/42">Tools</p>
					<a href={getLocalePath(locale)} class="flex h-9 items-center rounded-md px-2 font-medium text-white/72 transition hover:bg-white/10 hover:text-white">{copy.home}</a>
				</div>
				<div class="mt-auto">
					<p class="mb-2 px-2 text-xs font-semibold uppercase tracking-[0.18em] text-white/42">More</p>
					<a href={`${routePrefix}/help/`.replace('//', '/')} class:list={['flex h-9 items-center rounded-md px-2 font-medium transition', kind === 'help' ? 'bg-white/12 text-white' : 'text-white/72 hover:bg-white/10 hover:text-white']}>{copy.help}</a>
					<a href={`${routePrefix}/settings/`.replace('//', '/')} class:list={['mt-1 flex h-9 items-center rounded-md px-2 font-medium transition', kind === 'settings' ? 'bg-white/12 text-white' : 'text-white/72 hover:bg-white/10 hover:text-white']}>{copy.settings}</a>
				</div>
			</nav>
		</aside>

		<div class="min-w-0 flex-1">
			<header class="sticky top-0 z-40 flex h-16 shrink-0 items-center gap-3 border-b border-[var(--line)] bg-[rgba(251,250,247,0.92)] px-4 backdrop-blur-xl md:px-6 lg:px-8">
				<a href={getLocalePath(locale)} class="flex items-center gap-3 md:hidden">
					<img src="/pdfking-logo.svg" alt="PDFKING logo" class="size-9" />
					<span class="text-sm font-semibold text-[var(--ink)]">PDFKING</span>
				</a>
				<nav class="ml-auto hidden items-center text-sm font-medium text-[var(--muted)] sm:flex" aria-label="Breadcrumb">
					<a href={getLocalePath(locale)} class="hover:text-[var(--ink)]">{copy.home}</a>
					<span class="mx-2">/</span>
					<span class="text-[var(--ink)]" aria-current="page">{copy.title}</span>
				</nav>
				<div class="ml-auto sm:ml-4">
					<LanguageSwitcher locale={locale} />
				</div>
			</header>

			<main class="h-[calc(100vh-4rem)] overflow-y-auto bg-[var(--paper)]">
				<div class="mx-auto max-w-[1600px] space-y-8 p-6 md:p-12">
					<section class="space-y-4 text-center">
						<h1 class="text-4xl font-bold tracking-tight text-[var(--ink)]">{copy.title}</h1>
						<p class="mx-auto max-w-2xl text-lg leading-8 text-[var(--muted)]">{copy.description}</p>
					</section>
					<section class="grid gap-4 md:grid-cols-3">
						{copy.cards.map(([title, description]) => (
							<article class="rounded-2xl border border-[var(--line)] bg-white p-6">
								<h2 class="text-lg font-medium text-[var(--ink)]">{title}</h2>
								<p class="mt-3 text-sm leading-7 text-[var(--muted)]">{description}</p>
							</article>
						))}
					</section>
				</div>
			</main>
		</div>
	</div>
</Layout>
