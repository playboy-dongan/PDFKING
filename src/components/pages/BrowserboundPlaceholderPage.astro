---
import Layout from '../../layouts/Layout.astro';
import { browserboundSectionLabels, formatBrowserboundSlug } from '../../data/browserbound-routes';

const { section, slug } = Astro.props as { section: string; slug?: string };
const sectionLabel = browserboundSectionLabels[section] ?? 'Tools';
const title = slug ? formatBrowserboundSlug(slug) : sectionLabel;
const description = slug
	? `${title} is reserved in the BrowserBound-compatible tool catalog.`
	: `${sectionLabel} catalog reserved for the BrowserBound-compatible dashboard.`;
---

<Layout title={`${title} - BrowserBound Tools`} description={description}>
	<div class="flex min-h-svh w-full bg-background">
		<aside class="hidden h-svh w-64 shrink-0 bg-sidebar text-sidebar-foreground md:flex md:flex-col">
			<div class="flex h-16 items-center gap-3 border-b border-border p-4">
				<img src="https://www.browserbound.com/icons/icon-512x512.png" width="36" height="36" alt="BrowserBound" class="rounded-md" />
				<span class="text-base font-medium">BrowserBound</span>
			</div>
			<nav class="flex flex-1 flex-col gap-1 p-4 text-sm">
				<a href="/" class="flex h-9 items-center rounded-md px-2 font-medium text-sidebar-foreground/70 hover:bg-sidebar-accent hover:text-sidebar-accent-foreground">Home</a>
				<a href="/image-tools" class="flex h-9 items-center rounded-md px-2 font-medium text-sidebar-foreground/70 hover:bg-sidebar-accent hover:text-sidebar-accent-foreground">Image Tools</a>
				<a href="/pdf-tools" class="flex h-9 items-center rounded-md px-2 font-medium text-sidebar-foreground/70 hover:bg-sidebar-accent hover:text-sidebar-accent-foreground">PDF Tools</a>
				<a href="/text-tools" class="flex h-9 items-center rounded-md px-2 font-medium text-sidebar-foreground/70 hover:bg-sidebar-accent hover:text-sidebar-accent-foreground">Text Tools</a>
				<a href="/misc-tools" class="flex h-9 items-center rounded-md px-2 font-medium text-sidebar-foreground/70 hover:bg-sidebar-accent hover:text-sidebar-accent-foreground">Misc Tools</a>
			</nav>
		</aside>
		<div class="min-w-0 flex-1">
			<header class="flex h-16 items-center border-b border-border bg-background px-4 md:px-8">
				<div class="text-sm font-medium text-muted-foreground">
					<a href="/" class="hover:text-foreground">Home</a>
					<span class="px-2">/</span>
					<a href={`/${section}`} class="hover:text-foreground">{sectionLabel}</a>
					{slug && <span class="px-2">/</span>}
					{slug && <span class="text-foreground">{title}</span>}
				</div>
			</header>
			<main class="container mx-auto px-4 py-16 sm:px-6 lg:px-8">
				<div class="mx-auto max-w-2xl rounded-2xl border border-border bg-card p-8 text-center shadow-sm">
					<div class="mx-auto mb-5 flex size-14 items-center justify-center rounded-2xl bg-secondary text-primary">
						<span class="text-xl font-semibold">{title.slice(0, 1)}</span>
					</div>
					<p class="mb-2 text-sm font-medium text-primary">{sectionLabel}</p>
					<h1 class="mb-4 text-3xl font-bold tracking-tight text-foreground md:text-4xl">{title}</h1>
					<p class="text-base leading-7 text-muted-foreground">
						This route is connected so the BrowserBound dashboard catalog can be browsed end-to-end. The production tool implementation can be added here without changing the dashboard layout.
					</p>
					<div class="mt-8 flex justify-center gap-3">
						<a href="/" class="inline-flex h-10 items-center justify-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow-sm transition hover:bg-primary/90">Back to dashboard</a>
						<a href="/pdf-tools/merge/" class="inline-flex h-10 items-center justify-center rounded-md border border-border bg-card px-4 text-sm font-medium text-foreground transition hover:bg-accent">Open Merge PDF</a>
					</div>
				</div>
			</main>
		</div>
	</div>
</Layout>
