---
import FaqList from '../FaqList.astro';
import LanguageSwitcher from '../LanguageSwitcher.astro';
import Layout from '../../layouts/Layout.astro';
import ToolCard from '../ToolCard.astro';
import ToolWorkbench from '../ToolWorkbench.astro';
import {
	buildToolSchema,
	getAlternates,
	getLocaleMeta,
	getLocalePath,
	getToolBySlug,
	getToolPageCopy,
	type Locale,
	type ToolSlug,
} from '../../data/tools';

const { locale, slug } = Astro.props as { locale: Locale; slug: ToolSlug };
const tool = getToolBySlug(locale, slug)!;
const copy = getToolPageCopy(locale);
const localeMeta = getLocaleMeta(locale);
const related = tool.related.map((item) => getToolBySlug(locale, item)).filter(Boolean);
const alternates = getAlternates(slug).map((item) => ({ hreflang: item.hreflang, href: new URL(item.href, Astro.site ?? Astro.url.origin).href }));
const schema = buildToolSchema(tool, Astro.url.href);
---

<Layout title={tool.title} description={tool.metaDescription} canonical={Astro.url.href} schema={schema} lang={localeMeta.htmlLang} alternates={alternates}>
	<header class="sticky top-0 z-40 border-b border-gray-100 bg-white/95 backdrop-blur">
		<div class="mx-auto flex h-16 max-w-screen-xl items-center justify-between px-4 lg:px-6">
			<a href={getLocalePath(locale)} class="flex items-center gap-3">
				<img src="/pdfking-logo.svg" alt="PDFKING logo" class="h-10 w-10" />
				<span class="text-xl font-semibold text-gray-950">PDFKING</span>
			</a>
			<nav class="hidden items-center gap-8 text-sm font-medium text-gray-600 lg:flex">
				<a href={getLocalePath(locale)} class="hover:text-blue-700">{copy.home}</a>
				<a href="#tool" class="hover:text-blue-700">{copy.tool}</a>
				<a href="#faq" class="hover:text-blue-700">{copy.faq}</a>
			</nav>
			<div class="flex items-center gap-3">
				<LanguageSwitcher locale={locale} slug={slug} />
				<a href={getLocalePath(locale, 'merge-pdf')} class="hidden rounded-lg bg-blue-700 px-5 py-2.5 text-sm font-medium text-white hover:bg-blue-800 sm:inline-flex">
					{copy.moreTools}
				</a>
			</div>
		</div>
	</header>

	<main>
		<section class="bg-gradient-to-b from-blue-50/70 via-white to-white px-4 py-12 lg:px-6 lg:py-16">
			<div class="mx-auto max-w-4xl text-center">
				<nav class="mb-6 text-sm text-gray-500">
					<a href={getLocalePath(locale)} class="hover:text-blue-700">{copy.home}</a>
					<span class="mx-2">/</span>
					<span class="font-medium text-gray-900">{tool.slug}</span>
				</nav>
				<p class="mb-5 inline-flex rounded-full bg-blue-100 px-4 py-2 text-sm font-semibold text-blue-700">{tool.categoryLabel}</p>
				<h1 class="mx-auto max-w-3xl text-4xl font-extrabold leading-tight tracking-tight text-gray-950 md:text-5xl lg:text-6xl">
					{tool.h1}
				</h1>
				<p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-gray-600">{tool.intro}</p>
				<div class="mt-8 flex flex-wrap justify-center gap-3">
					{tool.highlights.map((item) => (
						<span class="rounded-full border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm">{item}</span>
					))}
				</div>
			</div>
		</section>

		<section id="tool" class="bg-white px-4 pb-16 lg:px-6 lg:pb-24">
			<div class="mx-auto max-w-4xl">
				<ToolWorkbench tool={tool} />
			</div>
		</section>

		<section class="bg-gray-50 px-4 py-16 lg:px-6 lg:py-24">
			<div class="mx-auto grid max-w-screen-xl gap-8 lg:grid-cols-[1.05fr_0.95fr]">
				<div class="rounded-3xl border border-gray-200 bg-white p-8 shadow-sm">
					<p class="mb-3 text-sm font-semibold uppercase tracking-[0.24em] text-blue-700">{copy.howItWorksEyebrow}</p>
					<h2 class="mb-8 text-3xl font-extrabold tracking-tight text-gray-950 md:text-4xl">{copy.howItWorksTitle(tool.name)}</h2>
					<ol class="grid gap-5 md:grid-cols-3">
						{copy.steps.map((step, index) => (
							<li class="rounded-2xl bg-gray-50 p-5">
								<div class="mb-4 flex h-10 w-10 items-center justify-center rounded-full bg-blue-700 text-sm font-bold text-white">{index + 1}</div>
								<h3 class="mb-2 text-lg font-semibold text-gray-950">{step.title}</h3>
								<p class="text-sm leading-7 text-gray-600">{step.description}</p>
							</li>
						))}
					</ol>
				</div>

				<div class="rounded-3xl border border-gray-200 bg-white p-8 shadow-sm">
					<p class="mb-3 text-sm font-semibold uppercase tracking-[0.24em] text-blue-700">{copy.tool}</p>
					<p class="text-sm leading-8 text-gray-600">{tool.pageCopy}</p>
					<div class="mt-8 rounded-2xl bg-blue-700 p-6 text-white">
						<p class="mb-4 text-sm font-semibold uppercase tracking-[0.2em] text-blue-100">{copy.relatedEyebrow}</p>
						<div class="space-y-4">
							{related.map((relatedTool) => <ToolCard tool={relatedTool!} compact />)}
						</div>
					</div>
				</div>
			</div>
		</section>

		<section id="faq" class="bg-white px-4 py-16 lg:px-6 lg:py-24">
			<div class="mx-auto max-w-screen-md">
				<div class="mb-12 text-center">
					<p class="mb-3 text-sm font-semibold uppercase tracking-[0.24em] text-blue-700">FAQ</p>
					<h2 class="text-3xl font-extrabold tracking-tight text-gray-950 md:text-4xl">{copy.faqTitle(tool.name)}</h2>
					<p class="mt-4 text-gray-600 sm:text-lg">{copy.faqEyebrow}</p>
				</div>
				<FaqList items={tool.faqs} />
			</div>
		</section>
	</main>
</Layout>
