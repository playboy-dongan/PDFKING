---
import LanguageSwitcher from '../LanguageSwitcher.astro';
import Layout from '../../layouts/Layout.astro';
import ToolCard from '../ToolCard.astro';
import ToolWorkbench from '../ToolWorkbench.astro';
import {
	buildToolSchema,
	getAlternates,
	getCategoryCards,
	getLocaleMeta,
	getLocalePath,
	getToolBySlug,
	getToolPageCopy,
	getTools,
	type Locale,
	type ToolSlug,
} from '../../data/tools';

const { locale, slug } = Astro.props as { locale: Locale; slug: ToolSlug };
const tool = getToolBySlug(locale, slug)!;
const copy = getToolPageCopy(locale);
const tools = getTools(locale);
const categories = getCategoryCards(locale);
const categoryGroups = categories.map((category, index) => ({
	...category,
	id: `category-${index}`,
	tools: tools.filter((entry) => category.slugs.includes(entry.slug)),
}));
const localeMeta = getLocaleMeta(locale);
const related = tool.related.map((item) => getToolBySlug(locale, item)).filter(Boolean);
const alternates = getAlternates(slug).map((item) => ({ hreflang: item.hreflang, href: new URL(item.href, Astro.site ?? Astro.url.origin).href }));
const schema = buildToolSchema(tool, Astro.url.href);
const routePrefix = locale === 'zh-cn' ? '' : `/${locale}`;
const ui = locale === 'zh-cn'
	? {
			home: '首页',
			pdfTools: 'PDF 工具',
			toolsGroup: '工具',
			moreGroup: '更多',
			help: '帮助',
			settings: '设置',
			tagline: '本地优先 PDF 工具',
			secure: '安全私密',
			secureText: '核心处理优先在浏览器中完成，减少服务器依赖。',
			fast: '快速处理',
			fastText: '上传、预览、处理和下载集中在同一个页面。',
			offline: '可扩展',
			offlineText: '同一套工具页结构方便继续扩展更多 PDF 工具。',
		}
	: {
			home: 'Home',
			pdfTools: 'PDF Tools',
			toolsGroup: 'Tools',
			moreGroup: 'More',
			help: 'Help',
			settings: 'Settings',
			tagline: 'Local-first PDF tools',
			secure: 'Secure & Private',
			secureText: 'Core processing runs browser-first to reduce server dependency.',
			fast: 'Lightning Fast',
			fastText: 'Upload, preview, process, and download in one page.',
			offline: 'Scalable',
			offlineText: 'The same tool-page structure can expand to more PDF tools.',
		};
---

<Layout title={tool.title} description={tool.metaDescription} canonical={Astro.url.href} schema={schema} lang={localeMeta.htmlLang} alternates={alternates}>
	<div class="flex min-h-svh w-full bg-[var(--background)]">
		<aside class="sticky top-0 hidden h-svh w-64 shrink-0 bg-[var(--sidebar)] text-[var(--sidebar-foreground)] md:flex md:flex-col">
			<div class="flex h-16 items-center gap-3 px-4">
				<img src="/pdfking-logo.svg" alt="PDFKING logo" class="size-10 rounded-md bg-white p-1" />
				<div class="min-w-0">
					<p class="truncate text-sm font-semibold">PDFKING</p>
					<p class="truncate text-xs text-[var(--sidebar-foreground)]/55">{ui.tagline}</p>
				</div>
			</div>

			<nav class="flex min-h-0 flex-1 flex-col gap-5 overflow-y-auto p-4 text-sm">
				<div>
					<p class="mb-2 px-2 text-xs font-medium uppercase text-[var(--sidebar-foreground)]/50">{ui.toolsGroup}</p>
					<div class="grid gap-1">
						<a href={getLocalePath(locale)} class="flex h-9 items-center gap-3 rounded-md px-2 font-medium text-[var(--sidebar-foreground)]/72 transition hover:bg-[var(--sidebar-accent)] hover:text-[var(--sidebar-accent-foreground)]">
							<span class="inline-flex size-5 shrink-0 items-center justify-center rounded text-[10px] font-bold">P</span>
							<span>{ui.pdfTools}</span>
						</a>
						{categoryGroups.map((category) => (
							<a href={getLocalePath(locale)} class:list={['flex h-9 items-center justify-between gap-3 rounded-md px-2 font-medium transition', category.slugs.includes(tool.slug) ? 'bg-gradient-to-b from-[var(--sidebar-primary)] to-[rgba(240,81,0,0.7)] text-[var(--sidebar-foreground)] shadow-[0_1px_2px_0_rgb(0_0_0/.05),inset_0_1px_0_0_rgb(255_255_255/.12)]' : 'text-[var(--sidebar-foreground)]/72 hover:bg-[var(--sidebar-accent)] hover:text-[var(--sidebar-accent-foreground)]']}>
								<span class="truncate">{category.name}</span>
								<span class="rounded bg-white/10 px-1.5 py-0.5 text-xs text-[var(--sidebar-foreground)]/58">{category.tools.length}</span>
							</a>
						))}
					</div>
				</div>

				<div class="mt-auto">
					<p class="mb-2 px-2 text-xs font-medium uppercase text-[var(--sidebar-foreground)]/50">{ui.moreGroup}</p>
					<div class="grid gap-1">
						<a href={`${routePrefix}/help/`.replace('//', '/')} class="flex h-9 items-center rounded-md px-2 font-medium text-[var(--sidebar-foreground)]/72 transition hover:bg-[var(--sidebar-accent)] hover:text-[var(--sidebar-accent-foreground)]">{ui.help}</a>
						<a href={`${routePrefix}/settings/`.replace('//', '/')} class="flex h-9 items-center rounded-md px-2 font-medium text-[var(--sidebar-foreground)]/72 transition hover:bg-[var(--sidebar-accent)] hover:text-[var(--sidebar-accent-foreground)]">{ui.settings}</a>
					</div>
				</div>
			</nav>
		</aside>

		<div class="min-w-0 flex-1">
			<header class="sticky top-0 z-40 flex h-16 shrink-0 items-center gap-3 bg-[var(--sidebar)] px-4 text-[var(--sidebar-foreground)] md:px-6 lg:px-8 relative before:absolute before:inset-y-3 before:-left-px before:w-px before:bg-gradient-to-b before:from-white/5 before:via-white/15 before:to-white/5">
				<a href={getLocalePath(locale)} class="flex items-center gap-3 md:hidden">
					<img src="/pdfking-logo.svg" alt="PDFKING logo" class="size-9" />
					<span class="text-sm font-semibold text-[var(--sidebar-foreground)]">PDFKING</span>
				</a>
				<nav class="ml-auto hidden items-center text-sm font-medium sm:flex" aria-label="Breadcrumb">
					<a class="text-[var(--sidebar-foreground)]/50 transition-colors hover:text-[var(--sidebar-foreground)]/70" href={getLocalePath(locale)}>{ui.home}</a>
					<span class="px-3 text-[var(--sidebar-foreground)]/30">/</span>
					<a class="text-[var(--sidebar-foreground)]/50 transition-colors hover:text-[var(--sidebar-foreground)]/70" href={getLocalePath(locale)}>{ui.pdfTools}</a>
					<span class="px-3 text-[var(--sidebar-foreground)]/30">/</span>
					<span class="text-[var(--sidebar-foreground)]" aria-current="page">{tool.name}</span>
				</nav>
				<div class="ml-auto sm:ml-4">
					<LanguageSwitcher locale={locale} slug={slug} />
				</div>
			</header>

			<main class="h-[calc(100vh-4rem)] overflow-y-auto bg-[var(--background)]">
				<div class="flex flex-col bg-[var(--background)] transition-colors duration-300">
					<main class="container mx-auto flex-1 space-y-6 px-4 py-8 sm:px-6 lg:px-8">
						<div class="mx-auto mb-8 mt-12 max-w-2xl space-y-4 text-center">
							<h1 class="text-3xl font-bold tracking-tight text-[var(--foreground)] md:text-5xl">{tool.h1}</h1>
							<p class="text-lg leading-relaxed text-[var(--muted-foreground)]">{tool.intro}</p>
						</div>

						<div class="mx-auto max-w-4xl">
							<ToolWorkbench tool={tool} />
						</div>

						<div class="mx-auto grid max-w-6xl gap-6 pt-8 md:grid-cols-3">
							<div class="group rounded-2xl border border-[var(--border)] bg-[var(--card)] p-6 shadow-sm transition-all duration-300 hover:border-[var(--primary)]/20 hover:shadow-md">
								<div class="mb-4 flex size-12 items-center justify-center rounded-xl bg-[var(--primary)]/10 text-[var(--primary)] transition-all duration-300 group-hover:scale-110 group-hover:bg-[var(--primary)] group-hover:text-[var(--primary-foreground)]"></div>
								<h3 class="mb-2 text-lg font-semibold text-[var(--foreground)]">{ui.secure}</h3>
								<p class="text-sm leading-relaxed text-[var(--muted-foreground)]">{ui.secureText}</p>
							</div>
							<div class="group rounded-2xl border border-[var(--border)] bg-[var(--card)] p-6 shadow-sm transition-all duration-300 hover:border-[var(--primary)]/20 hover:shadow-md">
								<div class="mb-4 flex size-12 items-center justify-center rounded-xl bg-[var(--primary)]/10 text-[var(--primary)] transition-all duration-300 group-hover:scale-110 group-hover:bg-[var(--primary)] group-hover:text-[var(--primary-foreground)]"></div>
								<h3 class="mb-2 text-lg font-semibold text-[var(--foreground)]">{ui.fast}</h3>
								<p class="text-sm leading-relaxed text-[var(--muted-foreground)]">{ui.fastText}</p>
							</div>
							<div class="group rounded-2xl border border-[var(--border)] bg-[var(--card)] p-6 shadow-sm transition-all duration-300 hover:border-[var(--primary)]/20 hover:shadow-md">
								<div class="mb-4 flex size-12 items-center justify-center rounded-xl bg-[var(--primary)]/10 text-[var(--primary)] transition-all duration-300 group-hover:scale-110 group-hover:bg-[var(--primary)] group-hover:text-[var(--primary-foreground)]"></div>
								<h3 class="mb-2 text-lg font-semibold text-[var(--foreground)]">{ui.offline}</h3>
								<p class="text-sm leading-relaxed text-[var(--muted-foreground)]">{ui.offlineText}</p>
							</div>
						</div>

						<div class="mx-auto max-w-6xl pt-4">
							<p class="mb-4 text-sm font-medium text-[var(--muted-foreground)]">{copy.relatedEyebrow}</p>
							<div class="grid gap-4 md:grid-cols-3">
								{related.map((relatedTool) => <ToolCard tool={relatedTool!} compact />)}
							</div>
						</div>
					</main>
				</div>
			</main>
		</div>
	</div>
</Layout>
