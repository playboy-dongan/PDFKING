---
import FaqList from '../FaqList.astro';
import LanguageSwitcher from '../LanguageSwitcher.astro';
import Layout from '../../layouts/Layout.astro';
import ToolCard from '../ToolCard.astro';
import {
	buildHomeSchema,
	getAlternates,
	getCategoryCards,
	getHomeCopy,
	getHomeSeo,
	getLocaleMeta,
	getLocalePath,
	getTools,
	type Locale,
} from '../../data/tools';

const { locale } = Astro.props as { locale: Locale };
const copy = getHomeCopy(locale);
const seo = getHomeSeo(locale);
const categories = getCategoryCards(locale);
const tools = getTools(locale);
const localeMeta = getLocaleMeta(locale);
const alternates = getAlternates().map((item) => ({ hreflang: item.hreflang, href: new URL(item.href, Astro.site ?? Astro.url.origin).href }));
const schema = buildHomeSchema(locale, Astro.url.href);
const featuredTools = tools.slice(0, 6);
const workflowTools = tools.slice(6, 10);
const categoryGroups = categories.map((category) => ({
	...category,
	tools: tools.filter((tool) => category.slugs.includes(tool.slug)),
}));
const ui = locale === 'zh-cn'
	? {
			open: '打开',
			directory: '工具目录',
			directoryHint: '高频 PDF 路由',
			allTools: '全部工具',
			quickAccess: '快速入口',
			staticSeo: '静态 SEO 页面',
			langs: '双语路由',
			account: '无需账号',
			openSource: '开源依赖',
			adSlot: '广告位预留',
			adHint: '页面结构已给横幅、原生广告和页脚广告留出稳定位置。',
		}
	: {
			open: 'Open',
			directory: 'Tool directory',
			directoryHint: 'High-intent PDF routes',
			allTools: 'All tools',
			quickAccess: 'Quick access',
			staticSeo: 'Static SEO pages',
			langs: 'Bilingual routes',
			account: 'No account',
			openSource: 'Open-source stack',
			adSlot: 'Ad slot reserved',
			adHint: 'The page structure keeps stable room for banner, native, and footer ad placements.',
		};
---

<Layout
	title={seo.title}
	description={seo.description}
	schema={schema}
	lang={localeMeta.htmlLang}
	alternates={alternates}
>
	<header class="sticky top-0 z-50 border-b border-[var(--line)] bg-[rgba(251,250,247,0.9)] backdrop-blur-xl">
		<div class="pdfking-container flex h-16 items-center justify-between gap-4">
			<a href={getLocalePath(locale)} class="flex items-center gap-3">
				<img src="/pdfking-logo.svg" alt="PDFKING logo" class="size-10" />
				<span class="text-lg font-semibold tracking-tight text-[var(--ink)]">PDFKING</span>
			</a>
			<nav class="hidden items-center gap-7 text-sm font-medium text-[var(--muted)] lg:flex">
				<a href="#tools" class="hover:text-[var(--ink)]">{copy.nav.allTools}</a>
				<a href="#categories" class="hover:text-[var(--ink)]">{copy.nav.categories}</a>
				<a href="#faq" class="hover:text-[var(--ink)]">{copy.nav.faq}</a>
			</nav>
			<div class="flex items-center gap-2">
				<LanguageSwitcher locale={locale} />
				<a href={getLocalePath(locale, 'merge-pdf')} class="hidden rounded-md bg-[var(--ink)] px-4 py-2 text-sm font-medium text-white transition hover:bg-[#2a251f] sm:inline-flex">
					{copy.nav.start}
				</a>
			</div>
		</div>
	</header>

	<main>
		<section class="pdfking-container grid gap-8 py-10 lg:grid-cols-[0.92fr_1.08fr] lg:py-16">
			<div class="flex min-w-0 flex-col justify-center">
				<p class="mb-5 inline-flex w-fit rounded-md border border-[var(--line)] bg-white px-3 py-1.5 text-sm font-medium text-[var(--muted)] shadow-sm">
					{copy.hero.badge}
				</p>
				<h1 class="max-w-3xl text-4xl font-bold leading-[1.02] tracking-tight text-[var(--ink)] md:text-5xl">
					{copy.hero.title}
				</h1>
				<p class="mt-5 max-w-2xl text-lg leading-8 text-[var(--muted)]">{copy.hero.description}</p>
				<div class="mt-7 flex flex-col gap-3 sm:flex-row">
					<a href={getLocalePath(locale, 'merge-pdf')} class="inline-flex items-center justify-center rounded-md bg-[var(--ink)] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#2a251f]">
						{copy.hero.primary}
						<span aria-hidden="true" class="ml-2">→</span>
					</a>
					<a href={getLocalePath(locale, 'pdf-to-word')} class="inline-flex items-center justify-center rounded-md border border-[var(--line-strong)] bg-white px-5 py-3 text-sm font-semibold text-[var(--ink)] transition hover:bg-[var(--accent-soft)]">
						{copy.hero.secondary}
					</a>
				</div>
				<div class="mt-7 flex flex-wrap gap-2">
					{copy.hero.pills.map((pill) => (
						<span class="rounded-md border border-[var(--line)] bg-white px-3 py-2 text-sm font-medium text-[var(--muted)]">{pill}</span>
					))}
				</div>
			</div>

			<div class="rounded-3xl border border-[var(--line)] bg-white p-3 shadow-[0_26px_80px_-54px_rgba(23,20,17,0.65)]">
				<div class="rounded-[1.25rem] border border-[var(--line)] bg-[var(--paper)] p-4 sm:p-6">
					<div class="flex items-center justify-between gap-4">
						<div>
							<p class="text-sm font-semibold text-[var(--ink)]">{ui.directory}</p>
							<p class="mt-1 text-sm text-[var(--muted)]">{ui.directoryHint}</p>
						</div>
						<span class="rounded-md bg-[var(--accent-soft)] px-3 py-1 text-xs font-semibold text-[var(--accent-ink)]">{tools.length} PDF</span>
					</div>

					<div class="mt-5 grid gap-3 sm:grid-cols-2">
						{featuredTools.map((tool) => (
							<a href={tool.path} class="rounded-2xl border border-[var(--line)] bg-white p-4 pdfking-card-hover">
								<div class="flex items-start justify-between gap-3">
									<div>
										<p class="text-sm font-semibold text-[var(--ink)]">{tool.name}</p>
										<p class="mt-1 text-xs text-[var(--muted)]">{tool.categoryLabel}</p>
									</div>
									<span class="text-xs font-medium text-[var(--faint)]">{ui.open}</span>
								</div>
							</a>
						))}
					</div>

					<div class="mt-5 rounded-2xl border border-dashed border-[var(--line-strong)] bg-white p-4">
						<p class="text-sm font-semibold text-[var(--ink)]">{ui.adSlot}</p>
						<p class="mt-2 text-sm leading-6 text-[var(--muted)]">{ui.adHint}</p>
					</div>
				</div>
			</div>
		</section>

		<section class="border-y border-[var(--line)] bg-white/64">
			<div class="pdfking-container grid gap-3 py-4 sm:grid-cols-2 lg:grid-cols-4">
				<div class="rounded-2xl border border-[var(--line)] bg-white p-4">
					<p class="text-2xl font-bold text-[var(--ink)]">{tools.length}</p>
					<p class="mt-1 text-sm text-[var(--muted)]">{ui.staticSeo}</p>
				</div>
				<div class="rounded-2xl border border-[var(--line)] bg-white p-4">
					<p class="text-2xl font-bold text-[var(--ink)]">2</p>
					<p class="mt-1 text-sm text-[var(--muted)]">{ui.langs}</p>
				</div>
				<div class="rounded-2xl border border-[var(--line)] bg-white p-4">
					<p class="text-2xl font-bold text-[var(--ink)]">0</p>
					<p class="mt-1 text-sm text-[var(--muted)]">{ui.account}</p>
				</div>
				<div class="rounded-2xl border border-[var(--line)] bg-white p-4">
					<p class="text-2xl font-bold text-[var(--ink)]">MIT+</p>
					<p class="mt-1 text-sm text-[var(--muted)]">{ui.openSource}</p>
				</div>
			</div>
		</section>

		<section id="tools" class="pdfking-container py-14 lg:py-20">
			<div class="mb-8 flex flex-col justify-between gap-4 lg:flex-row lg:items-end">
				<div class="max-w-2xl">
					<p class="mb-3 text-sm font-semibold uppercase tracking-[0.2em] text-[var(--faint)]">{copy.tools.eyebrow}</p>
					<h2 class="text-3xl font-bold tracking-tight text-[var(--ink)] md:text-4xl">{copy.tools.title}</h2>
					<p class="mt-4 text-lg leading-8 text-[var(--muted)]">{copy.tools.description}</p>
				</div>
				<a href={getLocalePath(locale, 'rotate-pdf')} class="inline-flex w-fit rounded-md border border-[var(--line-strong)] bg-white px-4 py-2 text-sm font-semibold text-[var(--ink)] transition hover:bg-[var(--accent-soft)]">
					{ui.allTools}
				</a>
			</div>
			<div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
				{tools.map((tool) => <ToolCard tool={tool} />)}
			</div>
		</section>

		<section id="categories" class="bg-white/72">
			<div class="pdfking-container py-14 lg:py-20">
				<div class="mb-8 max-w-2xl">
					<p class="mb-3 text-sm font-semibold uppercase tracking-[0.2em] text-[var(--faint)]">{copy.categories.eyebrow}</p>
					<h2 class="text-3xl font-bold tracking-tight text-[var(--ink)] md:text-4xl">{copy.categories.title}</h2>
				</div>
				<div class="grid gap-4 lg:grid-cols-4">
					{categoryGroups.map((category) => (
						<article class="rounded-2xl border border-[var(--line)] bg-white p-6 pdfking-card-hover">
							<h3 class="text-lg font-semibold text-[var(--ink)]">{category.name}</h3>
							<p class="mt-3 text-sm leading-7 text-[var(--muted)]">{category.description}</p>
							<div class="mt-5 grid gap-2">
								{category.tools.map((tool) => (
									<a href={tool.path} class="flex items-center justify-between rounded-md border border-[var(--line)] bg-[var(--paper)] px-3 py-2 text-sm font-medium text-[var(--ink)] transition hover:bg-[var(--accent-soft)]">
										<span>{tool.name}</span>
										<span aria-hidden="true">→</span>
									</a>
								))}
							</div>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="pdfking-container grid gap-6 py-14 lg:grid-cols-[1fr_0.72fr] lg:py-20">
			<div class="rounded-3xl border border-[var(--line)] bg-white p-6 lg:p-8">
				<p class="mb-3 text-sm font-semibold uppercase tracking-[0.2em] text-[var(--faint)]">{copy.seo.eyebrow}</p>
				<h2 class="text-3xl font-bold tracking-tight text-[var(--ink)] md:text-4xl">{copy.seo.title}</h2>
				<div class="mt-5 grid gap-4 text-base leading-8 text-[var(--muted)]">
					{copy.seo.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
				</div>
			</div>
			<div class="rounded-3xl border border-[var(--line)] bg-[var(--ink)] p-6 text-white lg:p-8">
				<p class="mb-3 text-sm font-semibold uppercase tracking-[0.2em] text-[var(--accent)]">{copy.ads.eyebrow}</p>
				<h2 class="text-3xl font-bold tracking-tight">{copy.ads.title}</h2>
				<ul class="mt-6 grid gap-3 text-sm leading-7 text-white/78">
					{copy.ads.items.map((item) => (
						<li class="rounded-2xl border border-white/12 bg-white/6 p-4">{item}</li>
					))}
				</ul>
			</div>
		</section>

		<section id="faq" class="bg-white/72">
			<div class="pdfking-container grid gap-8 py-14 lg:grid-cols-[0.72fr_1fr] lg:py-20">
				<div>
					<p class="mb-3 text-sm font-semibold uppercase tracking-[0.2em] text-[var(--faint)]">{copy.faq.eyebrow}</p>
					<h2 class="text-3xl font-bold tracking-tight text-[var(--ink)] md:text-4xl">{copy.faq.title}</h2>
				</div>
				<FaqList items={copy.faq.items} />
			</div>
		</section>
	</main>

	<footer class="border-t border-[var(--line)] bg-[var(--paper)]">
		<div class="pdfking-container grid gap-8 py-10 sm:grid-cols-2 lg:grid-cols-4">
			<div>
				<a href={getLocalePath(locale)} class="mb-4 flex items-center gap-3">
					<img src="/pdfking-logo.svg" alt="PDFKING logo" class="size-10" />
					<span class="text-lg font-semibold tracking-tight text-[var(--ink)]">PDFKING</span>
				</a>
				<p class="text-sm leading-7 text-[var(--muted)]">{copy.footer.description}</p>
			</div>
			<div>
				<h3 class="mb-4 text-sm font-semibold uppercase tracking-[0.18em] text-[var(--faint)]">{copy.footer.popularRoutes}</h3>
				<ul class="grid gap-3 text-sm font-medium text-[var(--muted)]">
					{tools.slice(0, 5).map((tool) => <li><a href={tool.path} class="hover:text-[var(--ink)]">{tool.name}</a></li>)}
				</ul>
			</div>
			<div>
				<h3 class="mb-4 text-sm font-semibold uppercase tracking-[0.18em] text-[var(--faint)]">{copy.footer.securityRoutes}</h3>
				<ul class="grid gap-3 text-sm font-medium text-[var(--muted)]">
					{workflowTools.map((tool) => <li><a href={tool.path} class="hover:text-[var(--ink)]">{tool.name}</a></li>)}
				</ul>
			</div>
			<div>
				<h3 class="mb-4 text-sm font-semibold uppercase tracking-[0.18em] text-[var(--faint)]">{ui.quickAccess}</h3>
				<ul class="grid gap-3 text-sm font-medium text-[var(--muted)]">
					{categories.map((category) => <li>{category.name}</li>)}
				</ul>
			</div>
		</div>
	</footer>
</Layout>
