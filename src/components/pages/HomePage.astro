---
import Layout from '../../layouts/Layout.astro';
import { browserboundDashboardHtml } from '../../data/browserbound-dashboard-snapshot';
import {
	buildHomeSchema,
	getAlternates,
	getHomeSeo,
	getLocaleMeta,
	type Locale,
} from '../../data/tools';

const { locale } = Astro.props as { locale: Locale };
const seo = getHomeSeo(locale);
const localeMeta = getLocaleMeta(locale);
const alternates = getAlternates().map((item) => ({ hreflang: item.hreflang, href: new URL(item.href, Astro.site ?? Astro.url.origin).href }));
const schema = buildHomeSchema(locale, Astro.url.href);
---

<Layout
	title={seo.title}
	description={seo.description}
	schema={schema}
	lang={localeMeta.htmlLang}
	alternates={alternates}
>
	<Fragment set:html={browserboundDashboardHtml} />
</Layout>

<script>
	const searchInput = document.querySelector<HTMLInputElement>('input[placeholder="Search all tools..."]');
	const filterButtons = [...document.querySelectorAll<HTMLButtonElement>('button')].filter((button) => {
		const label = button.textContent?.trim() ?? '';
		return ['All Tools', 'PDF Tools', 'Image Tools', 'Text Tools', 'Misc Tools'].some((item) => label.startsWith(item));
	});
	const cards = [...document.querySelectorAll<HTMLAnchorElement>('a[href^="/pdf-tools"], a[href^="/image-tools"], a[href^="/text-tools"], a[href^="/misc-tools"]')].filter((link) => link.querySelector('h3'));
	let activeCategory = 'all';

	function categoryForHref(href: string) {
		if (href.startsWith('/pdf-tools')) return 'pdf';
		if (href.startsWith('/image-tools')) return 'image';
		if (href.startsWith('/text-tools')) return 'text';
		if (href.startsWith('/misc-tools')) return 'misc';
		return 'all';
	}

	function categoryForButton(button: HTMLButtonElement) {
		const text = button.textContent?.toLowerCase() ?? '';
		if (text.includes('pdf tools')) return 'pdf';
		if (text.includes('image tools')) return 'image';
		if (text.includes('text tools')) return 'text';
		if (text.includes('misc tools')) return 'misc';
		return 'all';
	}

	function setButtonState() {
		for (const button of filterButtons) {
			const isActive = categoryForButton(button) === activeCategory;
			button.classList.toggle('bg-foreground', isActive);
			button.classList.toggle('text-background', isActive);
			button.classList.toggle('border-foreground', isActive);
			button.classList.toggle('bg-card', !isActive);
			button.classList.toggle('text-foreground', !isActive);
			button.classList.toggle('border-border', !isActive);
		}
	}

	function updateCards() {
		const query = (searchInput?.value ?? '').trim().toLowerCase();
		for (const card of cards) {
			const href = new URL(card.href, location.origin).pathname;
			const categoryMatch = activeCategory === 'all' || categoryForHref(href) === activeCategory;
			const searchMatch = !query || (card.textContent ?? '').toLowerCase().includes(query);
			card.classList.toggle('hidden', !(categoryMatch && searchMatch));
		}
	}

	for (const button of filterButtons) {
		button.addEventListener('click', () => {
			activeCategory = categoryForButton(button);
			setButtonState();
			updateCards();
		});
	}

	searchInput?.addEventListener('input', updateCards);
	setButtonState();
	updateCards();
</script>
