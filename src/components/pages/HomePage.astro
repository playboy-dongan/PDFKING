---
import FaqList from '../FaqList.astro';
import LanguageSwitcher from '../LanguageSwitcher.astro';
import Layout from '../../layouts/Layout.astro';
import ToolCard from '../ToolCard.astro';
import {
	buildHomeSchema,
	getAlternates,
	getCategoryCards,
	getHomeCopy,
	getHomeSeo,
	getLocaleMeta,
	getLocalePath,
	getTools,
	type Locale,
} from '../../data/tools';

const { locale } = Astro.props as { locale: Locale };
const copy = getHomeCopy(locale);
const seo = getHomeSeo(locale);
const categories = getCategoryCards(locale);
const tools = getTools(locale);
const localeMeta = getLocaleMeta(locale);
const alternates = getAlternates().map((item) => ({ hreflang: item.hreflang, href: new URL(item.href, Astro.site ?? Astro.url.origin).href }));
const schema = buildHomeSchema(locale, Astro.url.href);
const featuredTools = tools.slice(0, 6);
const workflowTools = tools.slice(6, 10);
---

<Layout
	title={seo.title}
	description={seo.description}
	schema={schema}
	lang={localeMeta.htmlLang}
	alternates={alternates}
>
	<header class="fixed left-0 right-0 top-0 z-40 border-b border-gray-100 bg-white/95 backdrop-blur">
		<div class="mx-auto flex max-w-screen-xl items-center justify-between px-4 py-4 lg:px-6">
			<a href={getLocalePath(locale)} class="flex items-center">
				<img src="/pdfking-logo.svg" alt="PDFKING logo" class="mr-3 h-9 w-9" />
				<span class="self-center whitespace-nowrap text-xl font-semibold text-gray-900">PDFKING</span>
			</a>
			<nav class="hidden items-center gap-8 text-sm font-medium text-gray-700 lg:flex">
				<a href="#tools" class="hover:text-blue-600">{copy.nav.allTools}</a>
				<a href="#features" class="hover:text-blue-600">{copy.nav.categories}</a>
				<a href="#faq" class="hover:text-blue-600">{copy.nav.faq}</a>
			</nav>
			<div class="flex items-center gap-3">
				<LanguageSwitcher locale={locale} />
				<a href={getLocalePath(locale, 'merge-pdf')} class="hidden rounded-lg bg-blue-700 px-5 py-2.5 text-sm font-medium text-white hover:bg-blue-800 focus:outline-none focus:ring-4 focus:ring-blue-300 sm:inline-flex">
					{copy.nav.start}
				</a>
			</div>
		</div>
	</header>

	<main class="pt-20">
		<section class="bg-white">
			<div class="mx-auto grid max-w-screen-xl px-4 py-16 lg:grid-cols-12 lg:gap-8 lg:px-6 lg:py-24 xl:gap-0">
				<div class="mr-auto place-self-center lg:col-span-7">
					<p class="mb-4 inline-flex rounded-full bg-blue-50 px-4 py-2 text-sm font-medium text-blue-700">{copy.hero.badge}</p>
					<h1 class="mb-6 max-w-3xl text-4xl font-extrabold leading-none tracking-tight text-gray-900 md:text-5xl xl:text-6xl">
						{copy.hero.title}
					</h1>
					<p class="mb-8 max-w-2xl text-lg font-light text-gray-500 lg:mb-10 lg:text-xl">{copy.hero.description}</p>
					<div class="flex flex-col gap-4 sm:flex-row">
						<a href={getLocalePath(locale, 'merge-pdf')} class="inline-flex items-center justify-center rounded-lg bg-blue-700 px-5 py-3 text-center text-base font-medium text-white hover:bg-blue-800 focus:ring-4 focus:ring-blue-300">
							{copy.hero.primary}
							<svg class="ml-2 h-5 w-5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
						</a>
						<a href={getLocalePath(locale, 'pdf-to-word')} class="inline-flex items-center justify-center rounded-lg border border-gray-300 px-5 py-3 text-center text-base font-medium text-gray-900 hover:bg-gray-100 focus:ring-4 focus:ring-gray-100">
							{copy.hero.secondary}
						</a>
					</div>
					<div class="mt-8 flex flex-wrap gap-3">
						{copy.hero.pills.map((pill) => (
							<span class="rounded-lg bg-gray-100 px-3 py-2 text-sm font-medium text-gray-700">{pill}</span>
						))}
					</div>
				</div>

				<div class="hidden lg:col-span-5 lg:mt-0 lg:flex">
					<div class="relative w-full rounded-3xl border border-gray-200 bg-white p-6 shadow-2xl shadow-blue-100">
						<div class="absolute -left-6 -top-6 h-28 w-28 rounded-full bg-blue-100 blur-2xl"></div>
						<div class="absolute -bottom-8 right-0 h-36 w-36 rounded-full bg-cyan-100 blur-2xl"></div>
						<div class="relative rounded-2xl border border-gray-100 bg-gray-50 p-5">
							<div class="flex items-center justify-between">
								<div class="flex items-center">
									<img src="/pdfking-logo.svg" alt="" class="mr-3 h-10 w-10" />
									<div>
										<p class="text-sm font-semibold text-gray-900">PDFKING</p>
										<p class="text-xs text-gray-500">{copy.stack.eyebrow}</p>
									</div>
								</div>
								<span class="rounded-full bg-green-100 px-3 py-1 text-xs font-semibold text-green-700">Online</span>
							</div>
							<div class="mt-6 grid gap-3">
								{featuredTools.slice(0, 4).map((tool) => (
									<a href={tool.path} class="flex items-center justify-between rounded-xl border border-gray-200 bg-white p-4 hover:border-blue-200 hover:bg-blue-50">
										<div>
											<p class="text-sm font-semibold text-gray-900">{tool.name}</p>
											<p class="text-xs text-gray-500">{tool.categoryLabel}</p>
										</div>
										<span class="text-sm font-semibold text-blue-700">Open</span>
									</a>
								))}
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="bg-white">
			<div class="mx-auto max-w-screen-xl px-4 py-8 lg:px-6">
				<div class="grid grid-cols-2 gap-8 text-gray-500 sm:grid-cols-3 lg:grid-cols-6">
					{tools.slice(0, 6).map((tool) => (
						<a href={tool.path} class="flex items-center justify-center rounded-xl border border-gray-100 bg-gray-50 px-4 py-3 text-center text-sm font-semibold text-gray-700 hover:border-blue-200 hover:text-blue-700">
							{tool.name}
						</a>
					))}
				</div>
			</div>
		</section>

		<section id="tools" class="bg-gray-50">
			<div class="mx-auto max-w-screen-xl px-4 py-16 lg:px-6 lg:py-24">
				<div class="mx-auto mb-12 max-w-screen-md text-center">
					<h2 class="mb-4 text-4xl font-extrabold tracking-tight text-gray-900">{copy.tools.title}</h2>
					<p class="text-gray-500 sm:text-xl">{copy.tools.description}</p>
				</div>
				<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
					{featuredTools.map((tool) => <ToolCard tool={tool} />)}
				</div>
			</div>
		</section>

		<section id="features" class="bg-white">
			<div class="mx-auto max-w-screen-xl px-4 py-16 lg:px-6 lg:py-24">
				<div class="grid gap-12 lg:grid-cols-2 lg:items-center">
					<div class="text-gray-500 sm:text-lg">
						<h2 class="mb-4 text-4xl font-extrabold tracking-tight text-gray-900">{copy.seo.title}</h2>
						<div class="space-y-5 font-light">
							{copy.seo.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
						</div>
						<ul class="mt-8 space-y-5 border-t border-gray-200 pt-8">
							{categories.map((category) => (
								<li class="flex items-start">
									<span class="mr-3 mt-1 inline-flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-blue-100 text-blue-700">
										<svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-7.5 7.5a1 1 0 01-1.414 0l-4-4A1 1 0 015.207 8.793L8.5 12.086l6.793-6.793a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
									</span>
									<span><strong class="font-semibold text-gray-900">{category.name}</strong> {category.description}</span>
								</li>
							))}
						</ul>
					</div>
					<div class="grid gap-4 sm:grid-cols-2">
						{workflowTools.map((tool, index) => (
							<div class:list={['rounded-2xl border p-6 shadow-sm', index === 1 ? 'border-blue-200 bg-blue-50 sm:translate-y-8' : 'border-gray-200 bg-white']}>
								<p class="mb-2 text-sm font-semibold text-blue-700">{tool.categoryLabel}</p>
								<h3 class="mb-3 text-xl font-bold text-gray-900">{tool.name}</h3>
								<p class="text-sm leading-7 text-gray-500">{tool.cardDescription}</p>
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

		<section class="bg-gray-50">
			<div class="mx-auto max-w-screen-xl px-4 py-16 lg:px-6 lg:py-24">
				<div class="grid gap-8 border-y border-gray-200 py-8 text-center sm:grid-cols-2 lg:grid-cols-4 lg:py-16">
					<div>
						<p class="mb-2 text-4xl font-extrabold text-gray-900">{tools.length}</p>
						<p class="font-light text-gray-500">SEO Routes</p>
					</div>
					<div>
						<p class="mb-2 text-4xl font-extrabold text-gray-900">2</p>
						<p class="font-light text-gray-500">Languages</p>
					</div>
					<div>
						<p class="mb-2 text-4xl font-extrabold text-gray-900">0</p>
						<p class="font-light text-gray-500">Account Required</p>
					</div>
					<div>
						<p class="mb-2 text-4xl font-extrabold text-gray-900">MIT</p>
						<p class="font-light text-gray-500">UI Template Base</p>
					</div>
				</div>
			</div>
		</section>

		<section class="bg-white">
			<div class="mx-auto max-w-screen-xl px-4 py-16 lg:px-6 lg:py-24">
				<div class="mx-auto max-w-screen-sm text-center">
					<h2 class="mb-4 text-4xl font-extrabold tracking-tight text-gray-900">{copy.ads.title}</h2>
					<p class="mb-8 text-gray-500 sm:text-xl">{copy.footer.description}</p>
					<a href={getLocalePath(locale, 'pdf-watermark')} class="rounded-lg bg-blue-700 px-5 py-3 text-base font-medium text-white hover:bg-blue-800 focus:ring-4 focus:ring-blue-300">
						{copy.hero.primary}
					</a>
				</div>
			</div>
		</section>

		<section id="faq" class="bg-gray-50">
			<div class="mx-auto max-w-screen-xl px-4 py-16 lg:px-6 lg:py-24">
				<div class="mx-auto mb-12 max-w-screen-md text-center">
					<h2 class="mb-4 text-4xl font-extrabold tracking-tight text-gray-900">{copy.faq.title}</h2>
					<p class="text-gray-500 sm:text-xl">{copy.faq.eyebrow}</p>
				</div>
				<div class="mx-auto max-w-screen-md">
					<FaqList items={copy.faq.items} />
				</div>
			</div>
		</section>
	</main>

	<footer class="bg-white">
		<div class="mx-auto max-w-screen-xl px-4 py-8 lg:px-6 lg:py-12">
			<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
				<div>
					<a href={getLocalePath(locale)} class="mb-5 flex items-center">
						<img src="/pdfking-logo.svg" alt="PDFKING logo" class="mr-3 h-9 w-9" />
						<span class="self-center whitespace-nowrap text-xl font-semibold text-gray-900">PDFKING</span>
					</a>
					<p class="text-sm leading-7 text-gray-500">{copy.footer.description}</p>
				</div>
				<div>
					<h3 class="mb-5 text-sm font-semibold uppercase text-gray-900">{copy.footer.popularRoutes}</h3>
					<ul class="space-y-3 text-gray-500">
						<li><a href={getLocalePath(locale, 'merge-pdf')} class="hover:text-blue-700">Merge PDF</a></li>
						<li><a href={getLocalePath(locale, 'split-pdf')} class="hover:text-blue-700">Split PDF</a></li>
						<li><a href={getLocalePath(locale, 'pdf-to-word')} class="hover:text-blue-700">PDF to Word</a></li>
					</ul>
				</div>
				<div>
					<h3 class="mb-5 text-sm font-semibold uppercase text-gray-900">{copy.footer.securityRoutes}</h3>
					<ul class="space-y-3 text-gray-500">
						<li><a href={getLocalePath(locale, 'unlock-pdf')} class="hover:text-blue-700">Unlock PDF</a></li>
						<li><a href={getLocalePath(locale, 'protect-pdf')} class="hover:text-blue-700">Protect PDF</a></li>
						<li><a href={getLocalePath(locale, 'pdf-watermark')} class="hover:text-blue-700">Watermark PDF</a></li>
					</ul>
				</div>
				<div>
					<h3 class="mb-5 text-sm font-semibold uppercase text-gray-900">{copy.nav.categories}</h3>
					<ul class="space-y-3 text-gray-500">
						{categories.map((category) => <li>{category.name}</li>)}
					</ul>
				</div>
			</div>
		</div>
	</footer>
</Layout>
