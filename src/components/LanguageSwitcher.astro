---
import type { Locale, ToolSlug } from '../data/tools';
import { getAlternates, getLocalePath } from '../data/tools';

const {
	locale,
	slug,
} = Astro.props as {
	locale: Locale;
	slug?: ToolSlug;
};

const links = getAlternates(slug);
---

<div class="flex items-center gap-1 rounded-md border border-[var(--line)] bg-white p-1 text-xs font-medium text-[var(--muted)] shadow-sm">
	{links.map((link) => (
		<a
			href={getLocalePath(link.code, slug)}
			class:list={[
				'rounded px-3 py-1.5 transition',
				link.code === locale ? 'bg-[var(--ink)] text-white' : 'hover:bg-[var(--paper)] hover:text-[var(--ink)]',
			]}
		>
			{link.label}
		</a>
	))}
</div>
