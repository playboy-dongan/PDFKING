---
import type { ToolDefinition } from '../data/tools';

const { tool, compact = false } = Astro.props as { tool: ToolDefinition; compact?: boolean };
---

<a
	href={tool.path}
	class:list={[
		'group block rounded-2xl border border-[var(--line)] bg-white pdfking-card-hover',
		compact ? 'p-4' : 'p-6',
	]}
>
	<div class="flex items-start justify-between gap-3">
		<div>
			<p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--faint)]">{tool.categoryLabel}</p>
			<h3 class="mt-2 text-lg font-semibold tracking-tight text-[var(--ink)]">{tool.name}</h3>
		</div>
		<span class="rounded-md border border-[var(--line)] bg-[var(--paper)] px-2 py-1 text-[11px] font-medium text-[var(--muted)]">/{tool.slug}</span>
	</div>
	<p class:list={[compact ? 'mt-3 text-sm leading-6' : 'mt-4 text-sm leading-7', 'text-[var(--muted)]']}>
		{compact ? tool.cardDescription : tool.metaDescription}
	</p>
	{!compact && (
		<p class="mt-5 inline-flex items-center gap-2 text-sm font-medium text-[var(--ink)]">
			Open tool
			<span aria-hidden="true" class="transition group-hover:translate-x-0.5">→</span>
		</p>
	)}
</a>
