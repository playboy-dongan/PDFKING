---
interface FaqItem {
	question: string;
	answer: string;
}

const { items } = Astro.props as { items: FaqItem[] };
---

<div class="grid gap-4">
	{items.map((item) => (
		<details class="group rounded-[1.7rem] border border-slate-200 bg-white p-6 transition open:shadow-sm">
			<summary class="flex cursor-pointer list-none items-center justify-between gap-6 pr-2 text-lg font-semibold text-slate-900 marker:hidden">
				<span>{item.question}</span>
				<span class="inline-flex size-9 items-center justify-center rounded-full border border-slate-200 bg-slate-50 text-slate-500 transition group-open:rotate-45 group-open:text-blue-600">
					+
				</span>
			</summary>
			<p class="mt-4 text-sm leading-7 text-slate-600">{item.answer}</p>
		</details>
	))}
</div>
