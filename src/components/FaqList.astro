---
interface FaqItem {
	question: string;
	answer: string;
}

const { items } = Astro.props as { items: FaqItem[] };
---

<div class="grid gap-3">
	{items.map((item) => (
		<details class="group rounded-2xl border border-[var(--line)] bg-white p-6 pdfking-card-hover open:border-[var(--line-strong)]">
			<summary class="flex cursor-pointer list-none items-center justify-between gap-6 pr-1 text-lg font-semibold text-[var(--ink)] marker:hidden">
				<span>{item.question}</span>
				<span class="inline-flex size-8 shrink-0 items-center justify-center rounded-md border border-[var(--line)] bg-[var(--paper)] text-[var(--muted)] transition group-open:rotate-45 group-open:bg-[var(--accent-soft)] group-open:text-[var(--accent-ink)]">
					+
				</span>
			</summary>
			<p class="mt-4 text-sm leading-7 text-[var(--muted)]">{item.answer}</p>
		</details>
	))}
</div>
